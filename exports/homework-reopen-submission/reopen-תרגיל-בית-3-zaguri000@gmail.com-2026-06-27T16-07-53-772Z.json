      "69ac3bd88c3f48ce26e80c67": {
        "sql": "select Students.StudentID , concat(Students.FirstName ,\" \", Students.LastName) as full_name, avg(Enrollments.Grade) as avg_grade\nfrom Enrollments  join Students join Courses\non (Enrollments.StudentID = Students.StudentID) \nand on Enrollments.CourseID = Courses.CourseID)\nwhere Courses.Department = 'Computer Science'\ngroup by Students.StudentID, concat(Students.FirstName ,\" \", Students.LastName)\nhaving avg(Enrollments.Grade) > (select avg(E2.Grade)\nfrom Enrollments as E2 join Courses as c2 on (E2.CourseID = c2.CourseID) \nwhere c2.Department = 'Computer Science')",
